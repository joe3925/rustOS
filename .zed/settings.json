{
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "linkedProjects": [
          "drivers/Cargo.toml",
          "kernel/Cargo.toml",
          "kernel_types/Cargo.toml",
          "third_party/rust-fatfs/Cargo.toml",
          "kernel_macros/Cargo.toml",
          "Cargo.toml",
        ],

        "cargo": {
          "target": "x86_64-pc-windows-msvc",
          "allTargets": false,
          "metadataExtraArgs": ["-Zjson-target-spec"],
          "extraArgs": ["-Zjson-target-spec"],
          "buildScripts": {
            "enable": true,
          },
        },

        "procMacro": {
          "enable": true,
        },

        "checkOnSave": true,

        "check": {
          "allTargets": false,
          "targets": ["x86_64-pc-windows-msvc"],
          "extraArgs": ["-Zjson-target-spec"],
        },

        "diagnostics": {
          "experimental": {
            "enable": false,
          },
        },
      },
    },
  },
}
