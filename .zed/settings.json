{
    "lsp": {
        "rust-analyzer": {
            "initialization_options": {
                "cargo": {
                    "metadataExtraArgs": ["-Zjson-target-spec"],
                    "extraArgs": ["-Zjson-target-spec"],
                },
                "diagnostics": {
                    "disabled": ["mismatched-types"],
                },
                "procMacro": {
                    "enable": true,
                },

                "check": {
                    "allTargets": false,
                    "extraArgs": ["-Zjson-target-spec"],
                },
                "checkOnSave": true,
                "linkedProjects": [
                    "drivers/Cargo.toml",
                    "kernel/Cargo.toml",
                    "rust-fatfs/Cargo.toml",
                    "Cargo.toml",
                ],
            },
        },
    },
}
