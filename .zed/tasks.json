[
  {
    "label": "build all",
    "command": "cargo",
    "args": ["run", "-p", "xtask", "--", "build", "--drivers"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "allow_concurrent_runs": false,
  },
  {
    "label": "build kernel",
    "command": "cargo",
    "args": ["run", "-p", "xtask"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "allow_concurrent_runs": false,
  },
  {
    "label": "debug kernel qemu",
    "command": "cargo",
    "args": ["run", "-p", "xtask", "--", "qemu", "--debug", "--detach"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "allow_concurrent_runs": false,
  },
  {
    "label": "no dbg full chain",
    "command": "cargo",
    "args": ["run", "-p", "xtask", "--", "qemu", "--console-serial"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "allow_concurrent_runs": false,
  },
]
