[
  {
    "label": "LLDB Rust Kernel EFI",
    "adapter": "CodeLLDB",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/target/debug/kernel.efi",
    "cwd": "$ZED_WORKTREE_ROOT",
    "build": "debug kernel qemu",
    "initCommands": [
      "settings set target.debug-file-search-paths \"drivers/target/x86_64-rustos-driver/debug/deps\"",
    ],
    "processCreateCommands": ["gdb-remote localhost:1234"],
    "postRunCommands": [
      "target modules load --file \"kernel.efi\" --slide 0",

      "target modules add \"target/debug/kernel.exe\"",
      "target modules load --file \"kernel.exe\" --slide 0",

      "command script import \".zed/lldb/rustos_meta.py\"",
      "rustos-meta-connect 127.0.0.1 4322 \"drivers/target/x86_64-rustos-driver/debug/deps\"",

      "process continue",
    ],
    "sourceLanguages": ["rust"],
  },
]
